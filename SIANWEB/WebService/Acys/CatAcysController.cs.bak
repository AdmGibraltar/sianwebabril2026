        // 3JUL-2019  RFH 
        // Actualiza el Estado de Autorizacion y envia MAIL a GERENTE
        // Y envia mail 
        [HttpPut]
        public eResponse<int> Enviar_Autorizacion_Gerente(
            int Id_Acs, int Acs_Version, int Id_Cte, int Id_Ter, int Acs_ReqAutGerente)
        {
            eResponse<int> result = new eResponse<int>();
            eAcys2ValiacionesPreAutorizacion VPAut = new eAcys2ValiacionesPreAutorizacion();

            int iStatus = 0;
            int verificador = 0;
            int iResponse = -1;

            // false - No Aplicar, true Aplicar 
            // Default APLICAR o true 
            bool VALIDACION_PRE_AUTORIZACION = true;

            try
            {
                Acys acys = new Acys();
                acys.Id_Emp = Sesion.Id_Emp;
                acys.Id_Cd = Sesion.Id_Cd_Ver;
                acys.Id_Acs = Id_Acs;

                // Validaciones Pereliminares
                CN_CapAcys2 CN_Val = new CN_CapAcys2();
                VPAut = CN_Val.Valizaciones_PreAutorizacion(
                    Sesion.Id_Emp, Sesion.Id_Cd, Id_Acs, Acs_Version, Sesion.Emp_Cnx);

                // Si Hay Algun Error ... Ya No Se Aplicara La Autorizacion 
                if (VPAut.ErrorSemanal > 0 || VPAut.ErrorMensual > 0 || VPAut.ErrorBimestral > 0 || VPAut.ErrorTrimestral > 0 ||
                    VPAut.ErrorSemestral > 0 || VPAut.Acs_Semana <= 0 || VPAut.Prods_SinTipoDoc > 0)
                {
                    VALIDACION_PRE_AUTORIZACION = false;
                    result.Estado = 9; // HAY ERROR
                }

                if (VALIDACION_PRE_AUTORIZACION)
                {
                    CN_CapAcys2 CN = new CN_CapAcys2();
                    CN.ConsultaUltimaVersion(ref acys, Sesion.Emp_Cnx);

                    CN_CapAcys2 cn_CA = new CN_CapAcys2();
                    verificador = cn_CA.Actualizar_Autorizacion_Gerente(
                        Sesion.Id_Emp, acys.Id_Cd, Id_Acs, Acs_ReqAutGerente,
                        Sesion.Emp_Cnx
                    );

                    result.Estado = 1;
                }
            }
            catch (Exception ex)
            {
                result.Estado = -1;
                result.Datos = 0;
                return result;
            }

            //
            // SOLO EL ESTATUS 1 ENVIARA MAIL y VALIDACION_PRE_AUTORIZACION = true 
            //
            if (Acs_ReqAutGerente == 1 && VALIDACION_PRE_AUTORIZACION)
            {
                try
                {
                    ConfiguracionGlobal configuracion = new ConfiguracionGlobal();
                    configuracion.Id_Cd = Sesion.Id_Cd_Ver;
                    configuracion.Id_Emp = Sesion.Id_Emp;
                    CN_Configuracion cn_configuracion = new CN_Configuracion();
                    cn_configuracion.Consulta(ref configuracion, Sesion.Emp_Cnx);

                    StringBuilder SB = new StringBuilder();

                    SB.Append("<div align='center'>");
                    SB.Append("<table style=\"border:1px solid: #000; width:500px\">");
                    SB.Append("<tr>");
                    SB.Append("<td>");
                    SB.Append("<IMG SRC=\"https://key.com.mx/templates/theme-org/images/presets/preset1/logo.png\" ALIGN='left'></td>");
                    SB.Append("</td>");
                    SB.Append("<td>");
                    SB.Append("<h1>Acuerdo Comercial y de Servicios (ACyS)");
                    SB.Append("</td>");
                    SB.Append("</tr>");
                    SB.Append("<td colspan=\"2\" align=\"center\">");
                    SB.Append("<h4>Se ha colocado una solicitud de autorización de acuerdo comercial </h4>");
                    SB.Append("</td>");
                    SB.Append("</tr>");
                    SB.Append("<tr>");
                    SB.Append("<td>");
                    SB.Append("<h4>Sucursal:" + Sesion.Id_Cd + " " + Sesion.Cd_Nombre + " </h4>");
                    SB.Append("</td>");
                    SB.Append("<td>");
                    SB.Append("<h4>No de folio :" + Id_Acs + " </h4>");
                    SB.Append("</td>");
                    SB.Append("</tr>");
                    SB.Append("<tr>");

                    string[] URL = HttpContext.Current.Request.Url.AbsoluteUri.ToString().Split(new char[] { '/' });

                    SB.Append("<td>");
                    //SB.Append("<p>1:" + URL[1] + "</p>");
                    //SB.Append("<p>2:" + URL[2] + "</p>");
                    //SB.Append("<p>3:" + URL[3] + "</p>");
                    //SB.Append("<p>4:" + URL[4] + "</p>");
                    SB.Append("</td>");

                    SB.Append("<td ");
                    SB.Append("style=\"font-family:'Helvetica Neue',Helvetica,sans-serif;");
                    SB.Append("color:white; width:100%; max-width:280px; text-decoration:none; text-align:center; ");
                    SB.Append("display:inline-block!important; font-size:16px; line-height:40px; -webkit-border-radius:2px;");
                    SB.Append("-moz-border-radius:2px; border-radius:2px; font-weight:bold; margin-top:0; margin-right:0; ");
                    SB.Append("margin-bottom:0; margin-left:0; padding-top:0; padding-right:0; padding-bottom:0; padding-left:0; background-color:#49b1ba\"");
                    SB.Append(">");

                    SB.Append("<a href=\"http://" + URL[2] + "/" + URL[3] + "/acys/CapAcys2_Index.aspx\"");

                    SB.Append("target=\"_blank\" ");
                    SB.Append("rel=\"noopener noreferrer\" ");
                    SB.Append("data-auth=\"NoApplicable\" ");
                    SB.Append("style=\"color:#FFFFFF; display:inline-block; text-decoration:none; magin:10px;\">");
                    SB.Append("Abrir SIANWEB");
                    SB.Append("</a>");

                    SB.Append("</td>");
                    SB.Append("</tr>");
                    SB.Append("</table></div>");
                    ServicePointManager.SecurityProtocol = SecurityProtocolType.Ssl3 | SecurityProtocolType.Tls | SecurityProtocolType.Tls11 | SecurityProtocolType.Tls12;
                    SmtpClient sm = new SmtpClient(configuracion.Mail_Servidor, Convert.ToInt32(configuracion.Mail_Puerto));
                    sm.Credentials = new NetworkCredential(configuracion.Mail_Usuario, configuracion.Mail_Contraseña);
                    sm.EnableSsl = true;

                    MailMessage m = new MailMessage();
                    m.From = new MailAddress(configuracion.Mail_Remitente);

                    // TODO: En produccion Actualizar.
                    //m.To.Add(new MailAddress("rfh@live.com.mx"));
                    //m.To.Add(new MailAddress(configuracion.Mail_Acys));
                    m.To.Add(new MailAddress(configuracion.mail_AutorizacionAcys_Gerente));

                    m.Subject = "Solicitud de autorización #" + Id_Acs + " del centro " + Sesion.Id_Cd_Ver;
                    m.SubjectEncoding = System.Text.Encoding.UTF8;
                    m.IsBodyHtml = true;
                    m.Body = SB.ToString();
                    m.BodyEncoding = System.Text.Encoding.UTF8;

                    try
                    {
                        result.Estado = 1;
                        sm.Send(m);
                    }
                    catch (Exception)
                    {
                        // Acualizado pero NO Enviado
                        result.Estado = 2;
                    }

                }
                catch (Exception ex)
                {
                    result.Estado = -2;
                }
            }
            result.Datos = 0;
            return result;
        }

        // 3JUL-2019  RFH 
        // Actualiza el Estado de Autorizacion y envia MAIL a JEFE OPREACIONES 
        // Y envia mail 
        [HttpPut]
        public eResponse<int> Enviar_Autorizacion_JefeOperacion(
            int Id_Acs, int Acs_Version, int Id_Cte, int Id_Ter, int Acs_ReqAutJefeOp)
        {

            eAcys2ValiacionesPreAutorizacion VPAut = new eAcys2ValiacionesPreAutorizacion();

            eResponse<int> result = new eResponse<int>();
            int iStatus = 0;
            int verificador = 0;
            int iResponse = -1;

            int iResult_GenerarCalendario = 0;


            // false - No Aplicar, true Aplicar 
            // Default APLICAR o true 
            bool VALIDACION_PRE_AUTORIZACION = true;

            try
            {
                // Validaciones Pereliminares
                CN_CapAcys2 CN_Val = new CN_CapAcys2();
                VPAut = CN_Val.Valizaciones_PreAutorizacion(
                    Sesion.Id_Emp, Sesion.Id_Cd, Id_Acs, Acs_Version, Sesion.Emp_Cnx);

                // Si Hay Algun Error ... Ya No Se Aplicara La Autorizacion 
                if (VPAut.ErrorSemanal > 0 || VPAut.ErrorMensual > 0 || VPAut.ErrorBimestral > 0 || VPAut.ErrorTrimestral > 0 ||
                    VPAut.ErrorSemestral > 0 || VPAut.Acs_Semana <= 0 || VPAut.Prods_SinTipoDoc > 0)
                {
                    VALIDACION_PRE_AUTORIZACION = false;
                    result.Estado = 9; // HAY ERROR
                }

                // SI NO YA ERROR EN VALIFACIONES
                if (VALIDACION_PRE_AUTORIZACION)
                {


                    //
                    // SI LA AUTORIZACON ES 2
                    // GENERA CALENDARIO DE ACYSDET
                    //
                    if (Acs_ReqAutJefeOp == 2)
                    {
                        CN_CapAcys2 CN = new CN_CapAcys2();
                        iResult_GenerarCalendario = CN.EXEC_spCapAcys_GenerarCalendario(Id_Acs, Sesion.Emp_Cnx);
                    }

                    //
                    // SE GENERO CALENDARIO CON EXITO 
                    //
                    if (Acs_ReqAutJefeOp == 1 || iResult_GenerarCalendario == 1)
                    {
                        // APLICA LA FIRMA EN AUTORIZACION ACYS
                        try
                        {
                            Acys acys = new Acys();
                            acys.Id_Emp = Sesion.Id_Emp;
                            acys.Id_Cd = Sesion.Id_Cd_Ver;
                            acys.Id_Acs = Id_Acs;

                            CN_CapAcys2 CN = new CN_CapAcys2();
                            CN.ConsultaUltimaVersion(ref acys, Sesion.Emp_Cnx);

                            CN_CapAcys2 cn_CA = new CN_CapAcys2();
                            verificador = cn_CA.Actualizar_Autorizacion_JefeOperacion(
                                Sesion.Id_Emp, acys.Id_Cd, Id_Acs, Acs_ReqAutJefeOp,
                                Sesion.Emp_Cnx
                            );
                            result.Estado = verificador;
                        }
                        catch (Exception ex)
                        {
                            result.Mensaje = "Ocurrio un error al intentar generar el calendario.";
                            result.Estado = -1;
                            result.Datos = 0;
                            return result;
                        }
                    }
                    else
                    {
                        // 
                        // REGRESA MENOS 2 
                        // 
                        result.Estado = -2;
                    }


                    //
                    // SOLO ENVIA EL MAIL EN EL ESTADO 1 
                    // Se envi mail al GERENTE 
                    // 
                    if (Acs_ReqAutJefeOp == 1)
                    {

                        try
                        {

                            ConfiguracionGlobal configuracion = new ConfiguracionGlobal();
                            configuracion.Id_Cd = Sesion.Id_Cd_Ver;
                            configuracion.Id_Emp = Sesion.Id_Emp;
                            CN_Configuracion cn_configuracion = new CN_Configuracion();
                            cn_configuracion.Consulta(ref configuracion, Sesion.Emp_Cnx);
                            ServicePointManager.SecurityProtocol = SecurityProtocolType.Ssl3 | SecurityProtocolType.Tls | SecurityProtocolType.Tls11 | SecurityProtocolType.Tls12;
                            SmtpClient sm = new SmtpClient(configuracion.Mail_Servidor, Convert.ToInt32(configuracion.Mail_Puerto));
                            sm.Credentials = new NetworkCredential(configuracion.Mail_Usuario, configuracion.Mail_Contraseña);
                            sm.EnableSsl = true;

                            MailMessage m = new MailMessage();
                            m.From = new MailAddress(configuracion.Mail_Remitente);
                            ENVIO_DE_EMAIL(Id_Acs, Sesion.Id_Cd, Sesion.Cd_Nombre, 0, configuracion.mail_AutorizacionAcys_JefeOperaciones, "Solictud Autorización.");

                        }
                        catch (Exception ex)
                        {
                            result.Estado = -3;
                        }
                    }

                }
            }
            catch (Exception ex)
            {
                result.Estado = -1;
                result.Datos = 0;
                return result;
            }

            result.Datos = 0;
            return result;
        }

        // 9JUL-2019 RFH 
        // APLICA RECHAZO AL DOCMENTO ACYS
        [HttpPut]
        public eResponse<int> Enviar_Rechazo_JefeOperacion(
             int Id_Acs, int Acs_Version, int Id_Cte, int Id_Ter, string Notas, int TipoUsuario)
        {
            eResponse<int> result = new eResponse<int>();
            int iStatus = 0;
            int verificador = 0;
            int iResponse = -1;
            int iResult_GenerarCalendario = 0;

            // APLICA LA FIRMA EN CANCELACION ACYS
            try
            {
                Acys acys = new Acys();
                acys.Id_Emp = Sesion.Id_Emp;
                acys.Id_Cd = Sesion.Id_Cd;
                acys.Id_Acs = Id_Acs;

                CN_CapAcys2 CN = new CN_CapAcys2();
                CN.ConsultaUltimaVersion(ref acys, Sesion.Emp_Cnx);

                CN_CapAcys2 cn_CA = new CN_CapAcys2();
                verificador = cn_CA.EXEC_spCapAcys_AplicarRechazo_ReqAutJefeOp(
                    Sesion.Id_Emp, acys.Id_Cd, Id_Acs, acys.Acs_Version, Sesion.Id_U, Notas, TipoUsuario, Sesion.Emp_Cnx
                );
                result.Estado = verificador;
            }
            catch (Exception ex)
            {
                result.Mensaje = "Ocurrio un error al intentar generar el calendario.";
                result.Estado = -1;
                result.Datos = 0;
                return result;
            }

            // 
            if (result.Estado > 0)
            {
                string sMailDeRik = "";
                // Extaer el mail del Rik del documento ACyS para envio de mail
                CN_CapAcys2 CN_mail = new CN_CapAcys2();
                sMailDeRik = CN_mail.EXEC_spCapAcys_MaildelRik(Sesion.Id_Emp, Sesion.Id_Cd, Id_Acs, 0, Sesion.Emp_Cnx);

                if (sMailDeRik.Length > 0)
                {

                    if (TipoUsuario == 1)
                    {
                        ENVIO_DE_EMAIL(Id_Acs, Sesion.Id_Cd, Sesion.Cd_Nombre, 1, sMailDeRik, Notas);
                    }
                    if (TipoUsuario == 2)
                    {
                        ENVIO_DE_EMAIL(Id_Acs, Sesion.Id_Cd, Sesion.Cd_Nombre, 2, sMailDeRik, Notas);
                    }
                }
            }

            result.Datos = 0;
            return result;
        }

        // ENVIAR - OBSOLETO 
        // Enviar ya no aplica es enviado para autorizacion a Gerente o Jefe de Op. 
        [HttpPut]
        public eResponse<int> Enviar(int Id_Acs, int Acs_Version, int Id_Cte, int Id_Ter, int Enviar)
        {
            eResponse<int> result = new eResponse<int>();
            int iStatus = 0;
            int verificador = 0;
            int iResponse = -1;

            try
            {
                Acys acys = new Acys();
                acys.Id_Emp = Sesion.Id_Emp;
                acys.Id_Cd = Sesion.Id_Cd_Ver;
                acys.Id_Acs = Id_Acs;

                CN_CapAcys2 CN = new CN_CapAcys2();
                CN.ConsultaUltimaVersion(ref acys, Sesion.Emp_Cnx);

                CN_CapAcys2 cn_CA = new CN_CapAcys2();
                verificador = cn_CA.Actualiza_Estatus(acys.Id_Emp, acys.Id_Cd, acys.Id_Acs, "S", Sesion.Emp_Cnx);
            }
            catch (Exception ex)
            {
                // Ocurrio un error  
                result.Estado = -1;
                result.Datos = 0;
                return result;
            }
            result.Datos = 0;
            return result;
        }

        [HttpPut]
        public int ENVIO_DE_EMAIL(int Id_Acs, int Id_Cd, string Cd_Nombre, int TipoTitulo, string mail_detino, string sObservaciones)
        {
            int iResultado = 0;

            ConfiguracionGlobal configuracion = new ConfiguracionGlobal();
            configuracion.Id_Cd = Sesion.Id_Cd_Ver;
            configuracion.Id_Emp = Sesion.Id_Emp;
            CN_Configuracion cn_configuracion = new CN_Configuracion();
            cn_configuracion.Consulta(ref configuracion, Sesion.Emp_Cnx);

            StringBuilder SB = new StringBuilder();
            SB.Append("<div align='center'>");
            SB.Append("<table style=\"border:1px solid: #000; width:500px\">");
            SB.Append("<tr>");
            SB.Append("<td>");
            SB.Append("<IMG SRC=\"https://key.com.mx/templates/theme-org/images/presets/preset1/logo.png\" ALIGN='left'></td>");
            SB.Append("</td>");
            SB.Append("<td>");

            if (TipoTitulo == 1)
            {
                SB.Append("<h1>Acuerdo Comercial y de Servicios");
            }
            if (TipoTitulo == 2)
            {
                SB.Append("<h4>Control de Ordenes</h4>");
            }

            SB.Append("</td>");
            SB.Append("</tr>");
            SB.Append("<td colspan=\"2\" align=\"center\">");

            if (TipoTitulo == 0)
            {
                SB.Append("<h4>Se ha colocado una solicitud de autorización</h4>");
            }
            if (TipoTitulo == 1)
            {
                SB.Append("<h4>Una solicitud ha sido rechazada por el Gerente</h4>");
            }
            if (TipoTitulo == 2)
            {
                SB.Append("<h4>Una solicitud ha sido rechazada por el Jefe de Operaciones</h4>");
            }

            SB.Append("</td>");
            SB.Append("</tr>");
            SB.Append("<tr>");
            SB.Append("<td>");
            SB.Append("<h4>Sucursal:" + Id_Cd + " " + Cd_Nombre + " </h4>");
            SB.Append("</td>");
            SB.Append("<td>");
            SB.Append("<h4>No de folio :" + Id_Acs + " </h4>");
            SB.Append("</td>");
            SB.Append("</tr>");
            SB.Append("<tr>");
            SB.Append("<td colspan=\"2\"");

            if (TipoTitulo == 1)
            {
                SB.Append("<label>Observaciones .-</label><i><p>" + sObservaciones + "</p></i>");
            }
            if (TipoTitulo == 2)
            {
                SB.Append("<label>Observaciones .-</label><i><p>" + sObservaciones + "</p></i>");
            }

            SB.Append("</td>");
            SB.Append("</tr><tr>");

            string[] URL = HttpContext.Current.Request.Url.AbsoluteUri.ToString().Split(new char[] { '/' });

            SB.Append("<td>");
            SB.Append("<p>" + URL[2] + "</p>");
            SB.Append("</td>");

            SB.Append("<td ");
            SB.Append("style=\"font-family:'Helvetica Neue',Helvetica,sans-serif;");
            SB.Append("color:white; width:100%; max-width:280px; text-decoration:none; text-align:center; ");
            SB.Append("display:inline-block!important; font-size:16px; line-height:40px; -webkit-border-radius:2px;");
            SB.Append("-moz-border-radius:2px; border-radius:2px; font-weight:bold; margin-top:0; margin-right:0; ");
            SB.Append("margin-bottom:0; margin-left:0; padding-top:0; padding-right:0; padding-bottom:0; padding-left:0; background-color:#49b1ba\"");
            SB.Append(">");

            SB.Append("<a href=\"http://" + URL[2] + "/" + URL[3] + "/acys/CapAcys2_Index.aspx\"");

            SB.Append("target=\"_blank\" ");
            SB.Append("rel=\"noopener noreferrer\" ");
            SB.Append("data-auth=\"NoApplicable\" ");
            SB.Append("style=\"color:#FFFFFF; display:inline-block; text-decoration:none; magin:10px;\">");
            SB.Append("Abrir SIANWEB");
            SB.Append("</a>");

            SB.Append("</td>");
            SB.Append("</tr>");
            SB.Append("</table></div>");
            ServicePointManager.SecurityProtocol = SecurityProtocolType.Ssl3 | SecurityProtocolType.Tls | SecurityProtocolType.Tls11 | SecurityProtocolType.Tls12;
            SmtpClient sm = new SmtpClient(configuracion.Mail_Servidor, Convert.ToInt32(configuracion.Mail_Puerto));
            sm.Credentials = new NetworkCredential(configuracion.Mail_Usuario, configuracion.Mail_Contraseña);
            sm.EnableSsl = true;

            MailMessage m = new MailMessage();
            m.From = new MailAddress(configuracion.Mail_Remitente);

            // TODO: En produccion Actualizar.
            //m.To.Add(new MailAddress("rfh@live.com.mx"));
            //m.To.Add(new MailAddress(configuracion.Mail_Acys));
            //m.To.Add(new MailAddress(configuracion.mail_AutorizacionAcys_JefeOperaciones));
            m.To.Add(new MailAddress(mail_detino));
            //m.Subject = "Solicitud de autorización #" + Id_Acs + " del centro " + Id_Cd;

            if (TipoTitulo == 0)
            {
                m.Subject = "Solicitud de Autorización #" + Id_Acs + " / Centro " + Id_Cd;
            }
            if (TipoTitulo == 1)
            {
                m.Subject = "Solicitud Rechazada por el Gerente #" + Id_Acs + " / Centro " + Id_Cd; ;
            }
            if (TipoTitulo == 2)
            {
                m.Subject = "Solicitud Rechazada por el Jefe de Operaciones #" + Id_Acs + " / Centro " + Id_Cd; ;
            }

            m.IsBodyHtml = true;
            string body = SB.ToString();
            AlternateView vistaHtml = AlternateView.CreateAlternateViewFromString(body, null, MediaTypeNames.Text.Html);

            m.AlternateViews.Add(vistaHtml);

            try
            {
                iResultado = 1;
                sm.Send(m);
            }
            catch (Exception)
            {
                iResultado = 2;
            }
            return iResultado;
        }

        protected Sesion Sesion
        {
            get
            {
                if (HttpContext.Current.Session != null)
                {
                    return (Sesion)HttpContext.Current.Session["Sesion" + HttpContext.Current.Session.SessionID];
                }
                return null;
            }
        }
        //
    }
