        // ELIMINAR 
        [HttpPut]
        public eResponse<int> Eliminar(int Id_Acs, int Id_AcsVersion, int Id_Cte, int Id_Ter, int Eliminar)
        {
            eResponse<int> result = new eResponse<int>();
            int iStatus = 0;
            int verificador = 0;
            try
            {
                CN_CapAcys2 cn_capacys = new CN_CapAcys2();
                Acys acys = new Acys();
                acys.Id_Emp = Sesion.Id_Emp;
                acys.Id_Cd = Sesion.Id_Cd;
                acys.Id_Acs = Id_Acs;
                acys.Id_AcsVersion = Id_AcsVersion;
                iStatus = cn_capacys.Eliminar(acys, Sesion.Id_U, Sesion.Emp_Cnx, ref verificador);
                result.Datos = iStatus;
                result.Estado = 1;
            }
            catch (Exception ex)
            {
                result.Estado = -1;
                result.Datos = 0;
            }

            return result;
        }

