            {
                List = CN.spAcuerdosExistentesPorCliente(
                    Sesion.Id_Emp, Sesion.Id_Cd, IdCte, IdRik, Sesion.Emp_Cnx);

                result.Estado = 1;
                result.Datos = List;
            }
            catch (Exception ex)
            {
                result.Estado = -1;
                result.Datos = null;
                result.Mensaje = ex.Message;
            }
            return result;
        }

        // REGRESA EL REGISTRO DE CONTRO DE ORDEN         
        // Abr 10-2019 RFH         
        [HttpGet]
        public eResponse<eAcys2> Get(int IdAcys, int AcsVersion)
        {
            eResponse<eAcys2> result = new eResponse<eAcys2>();
            result.Estado = 0;

            eAcys2 acys = new eAcys2();
            try
            {
                acys.Id_Emp = Sesion.Id_Emp;
                acys.Id_Cd = Sesion.Id_Cd;
                acys.Id_Acs = IdAcys;
                acys.Id_AcsVersion = AcsVersion;

                CN_CapAcys2 cn_capacys = new CN_CapAcys2();
                cn_capacys.Consultar_PorFolio(ref acys, Sesion.Id_U, Sesion.Emp_Cnx);

                result.Estado = 1;
                result.Datos = acys;

            }
            catch (Exception ex)
            {
                result.Estado = 0;
                result.Datos = null;
            }

            return result;
        }

