        // 3 JUN 2019 RFH - Regresa la lista de documentos ACYS Para el indice con paginacion.
        [HttpGet]
        public eResponse<List<eAcys2>> Get(
            int PageNumber, int PageSize,
            int AplicaFecha, string FechaIni, string FechaFin,
            int AplicaFolio, int FolioIni, int FolioFin,
            int AplicaCliente, int IdCte, string NombreCliente,
            string Estatus, int Vencido, Int32 Territorio, int IdRik,
            int Id_Modalidad)
        {
            /*
            List<eUsuarioRik> lst = new List<eUsuarioRik>();
            CN_UsuarioRik cn = new CN_UsuarioRik();
            lst = cn.Lista(Sesion.Id_Emp, Sesion.Id_Cd, Sesion.Emp_Cnx);
            return lst;
            */
            CN_CapAcys2 clsCapAcys = new CN_CapAcys2();
            //List<Acys> List = new List<Acys>();
            eResponse<List<eAcys2>> result = new eResponse<List<eAcys2>>();
            result.Estado = 0;
            result.Mensaje = "Inicio";
            result.Datos = null;
            List<eAcys2> List = new List<eAcys2>();

            try
            {
                eAcys2 acys = new eAcys2();

                acys.Id_Emp = Sesion.Id_Emp;
                acys.Id_Cd = Sesion.Id_Cd_Ver;
                acys.Filtro_FecIni = FechaIni;
                acys.Filtro_FecFin = FechaFin;
                acys.Filtro_Estatus = Estatus;
                acys.Acs_Vencido = Vencido.ToString();
                acys.Filtro_FolIni = FolioIni;
                acys.Filtro_FolFin = FolioFin;
                acys.Filtro_Usuario = Sesion.Id_U.ToString(); //"0" //Sesion.Id_U.ToString();
                acys.Id_Ter = Territorio;

                acys.Id_Cte = IdCte;
                acys.Cte_Nombre = ((NombreCliente == null) ? "" : NombreCliente);

                acys.Id_Rik = Sesion.Id_Rik;

                acys.Id_Modalidad = Id_Modalidad;
                // CORREGIR en Session.Id.TU -> debe ser -> Sesion.Id_U
                clsCapAcys.ConsultarAcys_Lista2(
                    PageNumber, PageSize,
                    AplicaFecha, AplicaFolio, AplicaCliente,
                    acys, Sesion.Emp_Cnx, ref List, Sesion.Id_U
                );

                result.Estado = 1;
                result.Datos = List;
            }
            catch (Exception ex)
            {
                result.Estado = -1;
                result.Datos = null;
                result.Mensaje = ex.Message;
            }
            return result;
        }

        // 21ABR-2021 - Regresa Los Acuerdos Existentes Por Cliente spAcuerdoExistentePorCliente
        [HttpGet]

        public eResponse<List<eAcys2>> spAcuerdosExistentesPorCliente(int IdCte, int IdRik)
        {
            CN_CapAcys2 CN = new CN_CapAcys2();
            eResponse<List<eAcys2>> result = new eResponse<List<eAcys2>>();
            List<eAcys2> List = new List<eAcys2>();
