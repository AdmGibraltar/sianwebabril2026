                </td>
                <td style="vertical-align:middle;">Por rango de folios&nbsp;</td>
                <td style="vertical-align:middle;">
                    <input type="checkbox" id="chbPorFolios" />&nbsp;
                </td>                
                <td style="vertical-align:middle;">Por cliente&nbsp;</td>
                <td style="vertical-align:middle;">
                    <input type="checkbox" id="chbPorCliente" />&nbsp;
                </td>   
                <td style="display:none;" style="vertical-align:middle;">Estatus</td>
                <td style="display:none;" >                    
                    <select id="ddlEstatus" class="form-control">
                        <option value="0">-- Todos --</option>
                        <option value="B">Baja</option>
                        <option value="C">Capturado</option>
                        <option value="S">Solicitado</option>
                        <option value="A">Autorizado</option>
                        <option value="R">Rechazado</option>
                    </select>
                </td style="display:none;">
                <td style="display:none;"  style="vertical-align:middle;">Vencido</td>
                <td style="display:none;" >
                    <select class="form-control">
                        <option value="0">-- Todos --</option>
                        <option value="1">SI</option>
                        <option value="2">NO</option>
                    </select>
                </td>
                <td style="display:none;"  style="vertical-align:middle;">Tipo de Modalidad</td>
                <td style="display:none;" style="width:150px;">
                    <select id="ddlModalidad" class="form-control">
                        <option value="0">-- Todos --</option>
                        <option value="1">REGULAR</option>
                        <option value="2">GARANTIA</option>                        
                    </select>
                </td>
            </tr>
        </table>        
    </div>
</div>

