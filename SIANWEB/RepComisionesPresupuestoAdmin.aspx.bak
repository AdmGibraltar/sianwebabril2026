                                                                            <dx:GridViewDataTextColumn  Caption="Ventas" FieldName="Real6" ShowInCustomizationForm="True" VisibleIndex="18"><HeaderStyle HorizontalAlign="Center"  Font-Size="Medium"   ForeColor="AliceBlue" BackColor="PowderBlue"></HeaderStyle></dx:GridViewDataTextColumn>
