                                                                            <dx:GridViewDataTextColumn  Caption="Ventas" FieldName="Real7" ShowInCustomizationForm="True" VisibleIndex="18"><HeaderStyle HorizontalAlign="Center"  Font-Size="Medium"   ForeColor="AliceBlue" BackColor="PowderBlue"></HeaderStyle></dx:GridViewDataTextColumn>
