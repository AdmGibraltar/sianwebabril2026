                                                                <dx:GridViewDataTextColumn Caption="Base Porc." FieldName="BaseUp_Porc" ShowInCustomizationForm="True"
                                                                    VisibleIndex="6">
                                                                     <HeaderStyle HorizontalAlign="Center" Font-Size="Medium"   ForeColor="AliceBlue" BackColor="PowderBlue"></HeaderStyle></dx:GridViewDataTextColumn>
                                                                
