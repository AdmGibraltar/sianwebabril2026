                            '<tr>' +
                            '<td>' +
                            '<input type = "checkbox" id="chkTipoPago_' + i + '" class="form-control chb" disabled = "disabled">' +
                            '</td>' +
                            '<td>' +
                            Lst[i].Fpa_Descripcion +
                            '</td>' +
                            '</tr>' +
                            '</table>';
                        $('#DivLstFormasPago').append(ObjTipoPago);
                        $('#chkTipoPago_' + i).attr('checked', true);
                    }
                },
                function (Lst) {
                    var MensajeError = '<label style="background-color:red; color:black;">ERROR: Al cargar intenta cargar listado de tipos pago.<label>';
                    $('#DivLstFormasPago').append(MensajeError);
