// Conuslta Listado de Formas de Pago de Cliente
function CatClienteFPago_Consultar(Id_Cte, CALLBACK_Exito, CALLBACK_Error, CALLBACK_Vacio) {

    $.ajax({
        url: _ApplicationUrl + '/api/CatFormaPago/CatClienteFPago_Consultar?Id_Cte=' + Id_Cte,
        cache: false,
        type: 'GET',
        statusCode: {
            //401: function (jqXHR, textStatus, errorThrown) {
            //    $('#dvDialogoInicioSesion').appendTo("body").modal();
            //    _onLoginSuccessful = $.proxy(Consulta_Producto, null, $, Id_Prd, rowno, Spinner, CALLBACK);
            //}
        }
    }).done(function (response, textStatus, jqXHR) {
        var Lst = response.Datos;
        var estado = response.Estado;

        if (estado == 1) {
            if (CALLBACK_Exito) {
                CALLBACK_Exito(Lst);
                if (Lst.length <= 0) {
                    CALLBACK_Vacio();
                }
            }
        } else {
            CALLBACK_Error();
            //alertify.error('Errro en consulta de formas de pago del Cliente.');
        }

    }).fail(function (jqXHR, textStatus, error) {
        if (jqXHR.status == 401) {
            //alert('La sessión ha expirado.');
            //$('#dvModalPropuestaTE_ver2').modal('hide');
            //$('#dvDialogoInicioSesion').appendTo("body").modal();
        } else {
            alertify.success('Ocurrió una error: funcion CatClienteFPago_Consultar.');
        }
    });
}



