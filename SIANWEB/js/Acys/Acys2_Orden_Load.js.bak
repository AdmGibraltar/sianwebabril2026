            $('#chkRevisionSabado').prop('checked', cte.Cte_RSabado);
            $('#chkRevisionDomingo').prop('checked', cte.Cte_RDomingo);
            $('#chkRevisionCualquierDia').prop('checked', cte.Cte_CualquierDia);

            //Horarios de revision
            $('#tpRevisionMañanaInicio').val(cte.Cte_RHoraam1);
            $('#tpRevisionMañanaFin').val(cte.Cte_RHoraam2);
            $('#tpRevisionTardeInicio').val(cte.Cte_RHorapm1);
            $('#tpRevisionTardeFin').val(cte.Cte_RHorapm2);

            // Documentos adicionales
            // TODO: Verificar Por que no esta los campos y si no estan que se va hacer 
            // 
            $('#chkRevFolio').prop('checked', false);
            $('#chkRevRntrada').prop('checked', false);
            $('#chkRevOrden').prop('checked', false);
            $('#chkRevReporte').prop('checked', false);
            $('#chkRevCopia').prop('checked', false);

            $('#tpRevisionTardeFin').val('');

            //
            // PAGO DE FACTURAS 
            //
            // OCT4-2019 
            // Correo para recibir facturas                                                      
            $('#tbAcs_CorreoRecibirFacturas').val(RES.Acs_CorreoRecibirFacturas);
            // Correo para recibir complemento
            $('#tbAcs_CorreoRecibirComplemento').val(RES.Acs_CorreoRecibirComplemento);

            if (RES.Acs_CorreoRecibir_NA == 1) {
                $('#chbAcs_CorreoRecibir_NA').prop('checked', true);
            } else {
                $('#chbAcs_CorreoRecibir_NA').prop('checked', false);
            }

            $('#chkPagoLunes').prop('checked', cte.Cte_CPLunes);
            $('#chkPagoMartes').prop('checked', cte.Cte_CPMartes);
            $('#chkPagoMiercoles').prop('checked', cte.Cte_CPMiercoles);
            $('#chkPagoJueves').prop('checked', cte.Cte_CPJueves);
            $('#chkPagoViernes').prop('checked', cte.Cte_CPViernes);
            $('#chkPagoSabado').prop('checked', cte.Cte_CPSabado);
            $('#chkPagoDomingo').prop('checked', cte.Cte_CPDomingo);
            $('#chkPagoCualquierDia').prop('checked', cte.Cte_CPCualquierDia);

            $('#tpPagoMañanaInicio').val(cte.Cte_PHoraam1);
            $('#tpPagoMañanaFin').val(cte.Cte_PHoraam2);
            $('#tpPagoTardeInicio').val(cte.Cte_PHorapm1);
            $('#tpPagoTardeFin').val(cte.Cte_PHorapm2);

            //
            // Presencial 
            //

            $('#chkRevFacContraEntrega').prop('checked', false); // NO ESTA 
            $('#chkRevFacVisGestorCobranza').prop('checked', false);
            $('#txtRevFacDireccion').val(cte.Cte_FacCalle + ' ' + cte.Cte_FacNumero); // NO ESTA 
            $('#txtRevFacColonia').val(cte.Cte_FacColonia);
            $('#txtRevFacMunicipio').val(cte.Cte_FacMunicipio);
            $('#txtRevFacEstado').val(cte.Cte_FacEstado);
            $('#txtRevFacCP').val(cte.Cte_FacCP);
            $('#txtRevFacCiudad').val('-');
            $('#txtRevFacTeléfonos').val(cte.Cte_FacTel);

            $('#CPH_chk').prop('checked', false);

            // Electronica
            /*
            $('#chkRevFacPortal').prop('checked', false); // NO ESTA
            $('#txtRevFacPortalTexto').val('');
            $('#txtRevFacHttp').val('');
            $('#txtRevFacUsuario').val('');
            $('#txtRevFacContrasenia').val('');
            */

            // 
            // ESPECIFICAIONES ADICIONALES 2 
            // 

            if (RES.ACS_chk62DocFactKeyEnt == 1 ||
                RES.ACS_txt62DocFactKeyEntCop.length > 0 ||
                RES.ACS_chk62DocFactKeyRec == 1 ||
                RES.ACS_txt62DocFactKeyRecCop.length > 0 ||
                RES.ACS_chk62DocOrdCompraEnt == 1 ||
                RES.ACS_txt62DocOrdCompraEntCop.length > 0 ||
                RES.ACS_chk62DocOrdCompraRec == 1 ||
                RES.ACS_txt62DocOrdCompraRecCop.length > 0 ||
                RES.ACS_chk62DocOrdReposEnt == 1 ||
                RES.ACS_txt62DocOrdReposEntCop.length > 0 ||
                RES.ACS_chk62DocOrdReposRec == 1 ||
                RES.ACS_txt62DocOrdReposRecCop.length > 0 ||
                RES.ACS_chk62DocCopPedidoEnt == 1 ||
                RES.ACS_txt62DocCopPedidoEntCop.length > 0 ||
                RES.ACS_chk62DocCopPedidoRec == 1 ||
                RES.ACS_txt62DocCopPedidoRecCop.length > 0 ||
                RES.ACS_chk62DocRemisionEnt == 1 ||
                RES.ACS_txt62DocRemisionEntCop.length > 0 ||
                RES.ACS_chk62DocRemisionRec == 1 ||
                RES.ACS_txt62DocRemisionRecCop.length > 0 ||

                RES.ACS_chk62DocCertificadoEnt == 1 ||
                RES.ACS_txt62DocCertificadoEntCop.length > 0 ||
                RES.ACS_chk62DocCertificadoRec == 1 ||
                RES.ACS_txt62DocCertificadoRecCop.length > 0

            ) {
                $('#divDER_EspecsAdic2').prop('checked', true);
                $('#divDER_EspecsAdic2').css('display', 'block');
            } else {
                $('#divDER_EspecsAdic2').prop('checked', false);
                $('#divDER_EspecsAdic2').css('display', 'none');
            }

            // Facturas KEY
            $('#chbACS_chk62DocFactKeyEnt').prop('checked', RES.ACS_chk62DocFactKeyEnt);
            $('#tbACS_txt62DocFactKeyEntCop').val(ReturnEmpty_WhenZero(RES.ACS_txt62DocFactKeyEntCop));
            $('#chbACS_chk62DocFactKeyRec').prop('checked', RES.ACS_chk62DocFactKeyRec);
            $('#tbACS_txt62DocFactKeyRecCop').val(ReturnEmpty_WhenZero(RES.ACS_txt62DocFactKeyRecCop));
            // Orden de compra/release
            $('#chbACS_chk62DocOrdCompraEnt').prop('checked', RES.ACS_chk62DocOrdCompraEnt);
            $('#tbACS_txt62DocOrdCompraEntCop').val(ReturnEmpty_WhenZero(RES.ACS_txt62DocOrdCompraEntCop));
            $('#chbACS_chk62DocOrdCompraRec').prop('checked', RES.ACS_chk62DocOrdCompraRec);
            $('#tbACS_txt62DocOrdCompraRecCop').val(ReturnEmpty_WhenZero(RES.ACS_txt62DocOrdCompraRecCop));
            // Orden de reposición                   
            $('#chbACS_chk62DocOrdReposEnt').prop('checked', RES.ACS_chk62DocOrdReposEnt);
            $('#tbACS_txt62DocOrdReposEntCop').val(ReturnEmpty_WhenZero(RES.ACS_txt62DocOrdReposEntCop));
            $('#chbACS_chk62DocOrdReposRec').prop('checked', RES.ACS_chk62DocOrdReposRec);
            $('#tbACS_txt62DocOrdReposRecCop').val(ReturnEmpty_WhenZero(RES.ACS_txt62DocOrdReposRecCop));
            // Copia de pedido                                  
            $('#chbACS_chk62DocCopPedidoEnt').prop('checked', RES.ACS_chk62DocCopPedidoEnt);
            $('#tbACS_txt62DocCopPedidoEntCop').val(ReturnEmpty_WhenZero(RES.ACS_txt62DocCopPedidoEntCop));
            $('#chbACS_chk62DocCopPedidoRec').prop('checked', RES.ACS_chk62DocCopPedidoRec);
            $('#tbACS_txt62DocCopPedidoRecCop').val(ReturnEmpty_WhenZero(RES.ACS_txt62DocCopPedidoRecCop));
            // Remisión                
            $('#chbACS_chk62DocRemisionEnt').prop('checked', RES.ACS_chk62DocRemisionEnt);
            $('#tbACS_txt62DocRemisionEntCop').val(ReturnEmpty_WhenZero(RES.ACS_txt62DocRemisionEntCop));
            $('#chbACS_chk62DocRemisionRec').prop('checked', RES.ACS_chk62DocRemisionRec);
            $('#tbACS_txt62DocRemisionRecCop').val(ReturnEmpty_WhenZero(RES.ACS_txt62DocRemisionRecCop));

            // /\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\
            // CERTIFICADO DE CALIDAD (2)            
            // /\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\
            /*
            $('#chbACS_chk62DocCertificadoEnt').prop('checked', RES.ACS_chk62DocCertificadoEnt);
            $('#tbACS_txt62DocCertificadoEntCop').val(ReturnEmpty_WhenZero(RES.ACS_txt62DocCertificadoEntCop));
            $('#chbACS_chk62DocCertificadoRec').prop('checked', RES.ACS_chk62DocCertificadoRec);
            $('#tbACS_txt62DocCertificadoRecCop').val(ReturnEmpty_WhenZero(RES.ACS_txt62DocCertificadoRecCop));
            */
            $('#chbACS_chk62DocCertificadoEnt').prop('checked', RES.CondPago_EA.CerChb1);
            $('#tbACS_txt62DocCertificadoEntCop').val(ReturnEmpty_WhenZero(RES.CondPago_EA.CerCopias1));
            $('#chbACS_chk62DocCertificadoRec').prop('checked', RES.CondPago_EA.CerChb2);
            $('#tbACS_txt62DocCertificadoRecCop').val(ReturnEmpty_WhenZero(RES.CondPago_EA.CerCopias2));

            $('#MensajeCargando').hide();

            //console.log('BOTONES 4');
            Enable_Btn('#btnOrden_Reducir');
            Enable_Btn('#btnOrden_Expandir');
            Enable_Btn('#btnOrdenCancelar');
            Enable_Btn('#btnOrdenGuardar');

            // Si no permite editar
            if (RES.Documento_PermiteEditara == "0") {
                Disable_Btn('#btnOrdenGuardar');
            }

            // SI REQUIERE AUTORIZACION 
            if (RES.Desplegar_BtnAutorizar == "1") {
                $('#btnOrdenAutorizarJefeOp').css('display', 'block');
                $('#btnOrdenRechazarJefeOp').css('display', 'block');
            } else {
                $('#btnOrdenAutorizarJefeOp').css('display', 'none');
                $('#btnOrdenRechazarJefeOp').css('display', 'none');
            }

            console.log('RES.Documento_PermiteEditara:' + RES.Documento_PermiteEditara);

            Spinner.css('display', 'none');
        });
        //Spinner.css('display', 'none');
        $('#btnConsultarAcys').data('id_acs', Id_Acs);
        $('#btnConsultarAcys').data('acs_version', Acs_Version);

    });
}

