function Acys2_Renovar(Id_Acs, Acs_Version, CALLBACK_Exito, CALLBACK_Error) {

    $.ajax({
        url: _ApplicationUrl + '/api/CatAcys/Renovar?Id_Acs=' + Id_Acs + '&Acs_version=' + Acs_Version,
        cache: false,
        type: 'PUT',
        contentType: "application/json; utf-8",
        dataType: "json",
        statusCode: {
            401: function (jqXHR, textStatus, errorThrown) {
                $('#dvDialogoInicioSesion').appendTo("body").modal();
                _onLoginSuccessful = $.proxy(Acys2_Renovar, null, $, Id_Acs, Acs_Version, CALLBACK_Exito, CALLBACK_Error);
            }
        }
    }).done(function (response, textStatus, jqXHR) {
        var RES = response.Datos;
        var Estado = response.Estado;
        if (Estado == 1) {
            alertify.alert('El Acuerdo se ha Renovado Exitosamente.');
            $('#btnCargarListado').trigger('click');
            CALLBACK_Exito(RES);
        } else if (Estado == 0 || Estado == 2 || Estado == 3 || Estado == -2) {
            if (Estado == 2) {
                alertify.alert('El Acuerdo comercial aún se encuentra Vigente.');
            }
            if (Estado == 3) {
                alertify.alert('El Acuerdo comercial se encuentra en estatus no válido para realizar la renovación.');
            }
            if (Estado == -2) {
                $('#btnAcys_Editar_' + Id_Acs).prop('disabled', false);
                $('#btnAcys_Editar_' + Id_Acs).css('color', 'black');
                alertify.alert('La frecuencia y tipo de frecuencia de tus productos no está definida o </br>actualizada, ' +
                    'realiza por favor las modificaciones en tu venta instalada e intenta nuevamente ACyS #: ' +
                    Id_Acs + '</br> (Se habilita modificación)');
            }

            // 2 .- El acuerdo comecial no esta vencido.
            //CALLBACK_Error(RES);
        } else {
            alertify.alert('Estatus: ' + Estado);
        }
    }).fail(function (jqXHR, textStatus, error) {
        if (jqXHR.status == 401) {
            alert('La sessión ha expirado.');
            $('#dvModalPropuestaTE_ver2').modal('hide');
            $('#dvDialogoInicioSesion').appendTo("body").modal();
        } else {
            alertify.success('Ocurrió una error: funcion Acys2_Renovar.');
        }
    });
}

