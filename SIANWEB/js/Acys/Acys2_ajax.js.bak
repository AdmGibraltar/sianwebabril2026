// Autorizacion GERENTE
function Enviar_Autorizacion_Gerente_Ajax(
    Id_Acs, Acs_Version, Id_Cte, Id_Ter, iTipoDoc,
    CALLBACK_Exito, CALLBACK_Error
) {

    $('#btnEnviar_Autorizacion_Gerente').prop('disabled', true);

    $.ajax({
        url: _ApplicationUrl + '/api/CatAcys/Enviar_Autorizacion_Gerente?' +
            'Id_Acs=' + Id_Acs +
            '&Acs_Version=' + Acs_Version +
            '&Id_Cte=' + Id_Cte +
            '&Id_Ter=0' +
            '&Acs_ReqAutGerente=1',
        cache: false,
        type: 'PUT',
        contentType: "application/json; utf-8",
        dataType: "json",
        statusCode: {
            401: function (jqXHR, textStatus, errorThrown) {
                $('#btnEnviar_Autorizacion_Gerente').prop('disabled', false);
                $('#dvDialogoInicioSesion').appendTo("body").modal();
                _onLoginSuccessful = $.proxy(Acys2_EsAutorizable, null, $, Id_Acs, Acs_Version, Id_Cte, Id_Ter, CALLBACK_Exito, CALLBACK_Error);
            }
        }
    }).done(function (response, textStatus, jqXHR) {
        var Estado = response.Estado;
        var RES = response.Datos;

        if (Estado == 1) {
            $('#btnEnviar_Autorizacion_Gerente').prop('disabled', false);
            CALLBACK_Exito(RES);
        } else {
            if (Estado == 9) {
                $('#btnEnviar_Autorizacion_Gerente').prop('disabled', false);

                alertify.alert('<b>Error en Validación del Documento(424)</b></br>' +
                    'Verificar:</br>' +
                    '1) Frecuencia de productos (La semanas NO pude ser 0)</br>' +
                    '2) Columna "Doc. de Entrega" en Listado de Productos</br>' +
                    '3) Columna "Requiere Orden Compra" en Listado de Productos</br>' +
                    '4) Vigencia semana Inicial.');

            } else {
                $('#btnEnviar_Autorizacion_Gerente').prop('disabled', false);
                CALLBACK_Error(RES);
            }
        }

    }).fail(function (jqXHR, textStatus, error) {
        $('#btnEnviar_Autorizacion_Gerente').prop('disabled', false);
        if (jqXHR.status == 401) {
            alert('La sessión ha expirado.');
            $('#dvModalPropuestaTE_ver2').modal('hide');
            $('#dvDialogoInicioSesion').appendTo("body").modal();
        } else {
            alertify.success('Ocurrió una error: funcion Enviar_Autorizacion_Gerente_Ajax.');
        }
    });
}

