function Acys2_DetalleProductos(Id_Acs, Id_AcsVersion, eACyS2, CALLBACK_Exito, CALLBACK_Error) {
    var sJSON = JSON.stringify(eACyS2);
    $.ajax({
        url: _ApplicationUrl + '/api/CatAcysDet/InsertUpdate?Id_Acs=' + Id_Acs + '&Id_AcsVersion=' + Id_AcsVersion,
        data: sJSON,
        cache: false,
        type: 'PUT',
        contentType: "application/json; utf-8",
        dataType: "json",
        statusCode: {
            401: function (jqXHR, textStatus, errorThrown) {
                $('#dvDialogoInicioSesion').appendTo("body").modal();
                _onLoginSuccessful = $.proxy(Acys2_DetalleProductos, null, $, Id_Acs, Id_AcsVersion, eACyS2, CALLBACK_Exito, CALLBACK_Error);
            }
        }
    }).done(function (response, textStatus, jqXHR) {
        var RES = response.Datos;
        var Estado = response.Estado;
        if (Estado == 1) {
            CALLBACK_Exito(RES);
        } else {
            CALLBACK_Error(RES);
        }

    }).fail(function (jqXHR, textStatus, error) {
        if (jqXHR.status == 401) {
            alert('La sessión ha expirado.');
            $('#dvModalPropuestaTE_ver2').modal('hide');
            $('#dvDialogoInicioSesion').appendTo("body").modal();
        } else {
            alertify.success('Ocurrió una error: funcion Acys2_DetalleProductos.');
        }
    });
}

function btnAutorizarAcys_Gerente_Ajax(
    Id_Acs, Acs_Version, Id_Cte, Id_Ter, Acs_ReqAutGerente,
    CALLBACK_Exito, CALLBACK_Error
) {
    $.ajax({
        url: _ApplicationUrl + '/api/CatAcys/Enviar_Autorizacion_Gerente?' +
            'Id_Acs=' + Id_Acs +
            '&Acs_Version=' + Acs_Version +
            '&Id_Cte=' + Id_Cte +
            '&Id_Ter=0' +
            '&Acs_ReqAutGerente=' + Acs_ReqAutGerente,
        cache: false,
        type: 'PUT',
        contentType: "application/json; utf-8",
        dataType: "json",
        statusCode: {
            401: function (jqXHR, textStatus, errorThrown) {
                $('#dvDialogoInicioSesion').appendTo("body").modal();
                _onLoginSuccessful = $.proxy(Acys2_EsAutorizable, null, $, Id_Acs, Acs_Version, Id_Cte, Id_Ter, CALLBACK_Exito, CALLBACK_Error);
            }
        }
    }).done(function (response, textStatus, jqXHR) {
        var Estado = response.Estado;
        var RES = response.Datos;

        /*if (Estado == 1) {
            CALLBACK_Exito(RES);
        } else {
            CALLBACK_Error(RES);
        }*/

        if (Estado == 1) {
            CALLBACK_Exito(RES);
        } else {
            if (Estado == 9) {

                alertify.alert('<b>Error en Validación de Documento(757)</b></br>' +
                    'Verificar:</br>' +
                    'Frecuencia de productos (La semanas NO pude ser 0),</br>' +
                    'Tipo de documento en listado de productos,</br>' +
                    'Vigencia semana Inicial.');

            } else {
                CALLBACK_Error(RES);
            }
        }


    }).fail(function (jqXHR, textStatus, error) {

        if (jqXHR.status == 401) {
            alert('La sessión ha expirado.');
            $('#dvModalPropuestaTE_ver2').modal('hide');
            $('#dvDialogoInicioSesion').appendTo("body").modal();
        } else {
            alertify.success('Ocurrió una error: funcion btnAutorizarAcys_Gerente_Ajax.');
        }
    });
}

function btnAutorizarControlDeOrden_JefeOp_Ajax(
    Id_Acs, Acs_Version, Id_Cte, Id_Ter, Acs_ReqAutJefeOp,
    CALLBACK_Exito, CALLBACK_Error
) {
    $.ajax({
        url: _ApplicationUrl + '/api/CatAcys/Enviar_Autorizacion_JefeOperacion?' +
            'Id_Acs=' + Id_Acs +
            '&Acs_Version=' + Acs_Version +
            '&Id_Cte=' + Id_Cte +
            '&Id_Ter=0' +
            '&Acs_ReqAutJefeOp=' + Acs_ReqAutJefeOp,
        cache: false,
        type: 'PUT',
        contentType: "application/json; utf-8",
        dataType: "json",
        statusCode: {
            401: function (jqXHR, textStatus, errorThrown) {
                $('#dvDialogoInicioSesion').appendTo("body").modal();
                _onLoginSuccessful = $.proxy(Acys2_EsAutorizable, null, $, Id_Acs, Acs_Version, Id_Cte, Id_Ter, CALLBACK_Exito, CALLBACK_Error);
            }
        }
    }).done(function (response, textStatus, jqXHR) {
        var Estado = response.Estado;
        var RES = response.Datos;

        if (Estado == 1 || Estado == 4 || Estado == 9) {
            if (Estado == 9) {
                alertify.alert('<b>No es posible aplicar la Autorización</b></br>' +
                    '* Atención Verificar *</br>' +
                    'El Listado de Productos Puede Estar Incompleto</br>' +
                    'Rechazar el Documento para que el RIk pueda hacer</br>' +
                    'las Correcciones.</br>');
            } else {
                CALLBACK_Exito(RES);
            }
        } else {
            CALLBACK_Error(RES);
        }

    }).fail(function (jqXHR, textStatus, error) {

        if (jqXHR.status == 401) {
            alert('La sessión ha expirado.');
            $('#dvModalPropuestaTE_ver2').modal('hide');
            $('#dvDialogoInicioSesion').appendTo("body").modal();
        } else {
            alertify.success('Ocurrió una error: funcion btnAutorizarControlDeOrden_JefeOp_Ajax.');
        }
    });
}

