function Acys2_Guardar(eACyS2, Spinner, CALLBACK_Exito, CALLBACK_Error) {
    Spinner.css('display', 'block');
    var sJSON = JSON.stringify(eACyS2);
    $.ajax({
        url: _ApplicationUrl + '/api/CatAcys/InsertUpdate',
        data: sJSON,
        cache: false,
        type: 'PUT',
        contentType: "application/json; utf-8",
        dataType: "json",
        async: false,
        statusCode: {
            401: function (jqXHR, textStatus, errorThrown) {
                $('#dvDialogoInicioSesion').appendTo("body").modal();
                _onLoginSuccessful = $.proxy(Acys2_Guardar, null, $, eACyS2, Spinner, CALLBACK_Exito, CALLBACK_Error);
            }
        }
    }).done(function (response, textStatus, jqXHR) {
        Spinner.css('display', 'none');
        var RES = response.Datos;
        var Estado = response.Estado;
        if (Estado == 1 || Estado == 2) {

            CALLBACK_Exito(RES, Estado);

            /*
            if (Estado == 2) {
                //alertify.success('Se generado un nuevo ducmento ACyS:'+ RES+'.');    
                alertify.alert('Se ha generado un nuevo documento ACyS:' + RES + '.');
            } else {
                alertify.alert('Se actualizo el documento ACyS:' + RES + '.');
            }
            */

        }
        if (Estado == -1) {
            CALLBACK_Error(RES);
        }

    }).fail(function (jqXHR, textStatus, error) {
        Spinner.css('display', 'none');
        if (jqXHR.status == 401) {
            alert('La sessión ha expirado.');
            $('#dvModalPropuestaTE_ver2').modal('hide');
            $('#dvDialogoInicioSesion').appendTo("body").modal();
        } else {
            alertify.success('Ocurrió una error: funcion Acys2_Guardar.');
        }
    });
}

function Acys2_Eliminar(Id_Acs, Acs_Version, Id_Cte, Id_Ter, CALLBACK_Exito, CALLBACK_Error) {

    $('#spinner_AcysIndice').css('display', 'block');

    $.ajax({
        url: _ApplicationUrl + '/api/CatAcys/Eliminar?Id_Acs=' + Id_Acs + '&Id_AcsVersion=' + Acs_Version + '&Id_Cte=' + Id_Cte + '&Id_Ter=0&Eliminar=1',
        cache: false,
        type: 'PUT',
        contentType: "application/json; utf-8",
        dataType: "json",
        statusCode: {
            401: function (jqXHR, textStatus, errorThrown) {
                $('#dvDialogoInicioSesion').appendTo("body").modal();
                _onLoginSuccessful = $.proxy(Acys2_Eliminar, null, $, Id_Acs, Acs_Version, Id_Cte, Id_Ter, CALLBACK_Exito, CALLBACK_Error);
            }
        }
    }).done(function (response, textStatus, jqXHR) {
        //Export_Excel_Informe1(response);
        //console.log(response);
        var RES = response.Datos;
        var Estado = response.Estado;

        if (Estado == 1) {
            if (RES == 3) {
                alertify.alert('<b>Mensaje</b> </br></br>El usuario actual no es el dueño del documento');
            }
            if (RES == 4) {
                alertify.alert('<b>Mensaje</b> </br></br>Se elimino con usuario Gerente');
            }
            if (RES == 5) {
                // lo elimina el usuario dueño.
                CALLBACK_Exito(RES);
            }
            if (RES == 2) {
                //alertify.success('No se puede aplicar NUEVAMENTE el estatus Eliminado.');
                alertify.alert('<b>Mensaje</b> </br></br>No se puede aplicar NUEVAMENTE el estatus Eliminado');
            }
        } else {
            CALLBACK_Error(RES);
        }
        $('#spinner_AcysIndice').css('display', 'none');

    }).fail(function (jqXHR, textStatus, error) {
        $('#spinner_AcysIndice').css('display', 'none');
        if (jqXHR.status == 401) {
            alert('La sessión ha expirado.');
            $('#dvModalPropuestaTE_ver2').modal('hide');
            $('#dvDialogoInicioSesion').appendTo("body").modal();
        } else {
            alertify.success('Ocurrió una error: funcion Acys2_Eliminar.');
        }
    });
}

