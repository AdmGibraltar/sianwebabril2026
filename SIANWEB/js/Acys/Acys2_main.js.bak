    */

    $('.datepicker').Zebra_DatePicker({
        format: 'd/m/Y'
    });

    $('.datepicker_sololunes').Zebra_DatePicker({
        format: 'd/m/Y',
        direction: true,
        disabled_dates: ['* * * 0,2,3,4,5,6'],
        onSelect: function () {
            $(this).change();
        }
    });

    $('#btnCargarListado').click(function () {
        //console.log('btnCargarListado');
        //Cargar_Indice(1, ACyS_RenglonesXPagina);
